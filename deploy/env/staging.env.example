# Staging environment — copy to deploy/env/staging.env on the VPS
# Do not commit real secrets.

NODE_ENV=production
PORT=3001
APP_PORT=3001

WEB_URL=https://staging.your-domain.com
API_URL=https://staging.your-domain.com

MONGODB_URI=mongodb://mongo:27017/li-facilitator-staging

JWT_SECRET=replace-with-long-random-staging-secret
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

STORAGE_ROOT=/app/storage
CORS_ORIGINS=
