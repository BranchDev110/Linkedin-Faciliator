# Production environment — copy to deploy/env/production.env on the VPS
# Do not commit real secrets.

NODE_ENV=production
PORT=3001
APP_PORT=3002

# Production VPS example (direct port — set your domain when using Nginx HTTPS)
# WEB_URL=http://83.229.67.146:3002
# API_URL=http://83.229.67.146:3002

WEB_URL=https://app.your-domain.com
API_URL=https://app.your-domain.com

MONGODB_URI=mongodb://mongo:27017/li-facilitator-production

JWT_SECRET=replace-with-long-random-production-secret
JWT_EXPIRES_IN=7d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

STORAGE_ROOT=/app/storage
CORS_ORIGINS=
