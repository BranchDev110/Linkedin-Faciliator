{
  "name": "li-facilitator",
  "version": "1.0.0",
  "private": true,
  "description": "LinkedIn Apply Facilitator - Chrome extension, React dashboard, and NestJS API",
  "workspaces": [
    "api",
    "web",
    "extension"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=api",
    "dev:web": "npm run dev --workspace=web",
    "build:api": "npm run build --workspace=api",
    "build:web": "npm run build --workspace=web",
    "build:extension": "npm run build --workspace=extension"
  },
  "engines": {
    "node": ">=18"
  }
}