# URLs
# When ngrok tunnels to the API (port 3001), use the same ngrok URL for both:
WEB_URL=https://your-subdomain.ngrok-free.dev
API_URL=https://your-subdomain.ngrok-free.dev
# Local development:
# WEB_URL=http://localhost:5173
# API_URL=http://localhost:3001
# ngrok on Vite (5173) with proxy: API_URL=https://YOUR-TUNNEL.ngrok-free.dev/api

# OpenAI (optional — defaults to gpt-5.4-mini)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini
