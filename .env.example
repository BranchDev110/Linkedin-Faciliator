# URLs (public site — same host serves API + dashboard in Docker/production)
WEB_URL=http://localhost:3001
API_URL=http://localhost:3001

# Local development with Vite dev server:
# WEB_URL=http://localhost:5173
# API_URL=http://localhost:3001

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/li-facilitator

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# File storage (resumes, templates)
STORAGE_ROOT=./storage

# OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=

# Docker Compose local port mapping
# APP_PORT=3001
