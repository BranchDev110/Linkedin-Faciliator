{
  "manifest_version": 3,
  "name": "LI Facilitator",
  "version": "1.0.7",
  "description": "Extract LinkedIn job details and generate tailored resumes with AI",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://garden-scrounger-unzip.ngrok-free.dev/*",
    "http://localhost:5173/*",
    "http://localhost:3001/*",
    "http://localhost:3002/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Toggle LI Facilitator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["voyager-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["sidebar-host.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://garden-scrounger-unzip.ngrok-free.dev/*",
        "http://localhost:5173/*",
        "http://localhost:3001/*",
        "http://localhost:3002/*"
      ],
      "js": ["web-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.js", "sidebar.css"],
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
